EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# シードスクリプト用（seed-expressions.js で使用）
# Supabase ダッシュボード → Settings → API → service_role キー
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# システムBOTユーザーのパスワード（seed-expressions.js で自動作成）
SYSTEM_BOT_PASSWORD=change-this-password

# ── Edge Function: ai-checker ─────────────────────────────────────────────
# Supabase ダッシュボード → Edge Functions → ai-checker → Secrets に設定すること
# （.env.local には不要。Edge Function 内でのみ参照される）
#
# プロバイダー選択（デフォルト: hf_toxic_bert）
# プロバイダー選択（すべて無料・デフォルト: openai）
# MODERATION_PROVIDER=openai          # OpenAI Moderation API（無料エンドポイント・日本語良好）★デフォルト
# MODERATION_PROVIDER=perspective     # Google Perspective API（日本語最強・無料 1 QPS）
# MODERATION_PROVIDER=hf_multilingual # HF multilingual-toxic-xlm-roberta（日本語可・完全無料）
# MODERATION_PROVIDER=hf_toxic_bert   # HF unitary/toxic-bert（英語特化・完全無料）
# ※ llm_judge は従量課金のため除外
#
# 各プロバイダーの必要トークン（取得手順: docs/moderation-setup.md）:
# OPENAI_API_KEY=sk-xxxx        ← openai で必要
# PERSPECTIVE_API_KEY=AIzaxxxx  ← perspective で必要
# HF_API_TOKEN=hf_xxxx          ← hf_toxic_bert / hf_multilingual で必要
