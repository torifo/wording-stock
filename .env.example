EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# シードスクリプト用（seed-expressions.js で使用）
# Supabase ダッシュボード → Settings → API → service_role キー
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# システムBOTユーザーのパスワード（seed-expressions.js で自動作成）
SYSTEM_BOT_PASSWORD=change-this-password

# ── Edge Function: ai-checker ─────────────────────────────────────────────
# Supabase ダッシュボード → Edge Functions → ai-checker → Secrets に設定すること
# （.env.local には不要。Edge Function 内でのみ参照される）
#
# プロバイダー選択（デフォルト: hf_toxic_bert）
# MODERATION_PROVIDER=hf_toxic_bert   # HF unitary/toxic-bert（英語特化）
# MODERATION_PROVIDER=hf_multilingual # HF multilingual-toxic-xlm-roberta（日本語可）
# MODERATION_PROVIDER=openai          # OpenAI Moderation API（無料・日本語良好）★推奨
# MODERATION_PROVIDER=perspective     # Google Perspective API（日本語最強）
# MODERATION_PROVIDER=llm_judge       # GPT-4o-mini ジャッジ（最も柔軟）
#
# 各プロバイダーの必要トークン:
# HF_API_TOKEN=hf_xxxx          ← hf_toxic_bert / hf_multilingual で必要
# OPENAI_API_KEY=sk-xxxx        ← openai / llm_judge で必要
# PERSPECTIVE_API_KEY=AIzaxxxx  ← perspective で必要
