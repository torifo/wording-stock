EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# シードスクリプト用（seed-expressions.js で使用）
# Supabase ダッシュボード → Settings → API → service_role キー
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# システムBOTユーザーのパスワード（seed-expressions.js で自動作成）
SYSTEM_BOT_PASSWORD=change-this-password

# Edge Function 用（Supabase ダッシュボード > Edge Functions > 環境変数 に設定）
# HF_API_TOKEN=hf_xxxx  ← Hugging Face 無料アクセストークン（https://huggingface.co/settings/tokens）
