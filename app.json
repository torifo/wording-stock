{
  "expo": {
    "name": "Wording Stock",
    "slug": "wording-stock",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "wordingstock",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.wordingstock.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.wordingstock.app"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/favicon.png",
      "name": "Wording Stock",
      "shortName": "語録",
      "description": "日本語の豊かな表現（四字熟語・慣用句・詩）を投稿・共有・発見できるSNS",
      "backgroundColor": "#FFFAF9",
      "themeColor": "#BC002D",
      "lang": "ja",
      "display": "standalone",
      "orientation": "portrait"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "newArchEnabled": true
  }
}
